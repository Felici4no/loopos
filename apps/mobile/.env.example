# LoopOS Mobile — variáveis de ambiente
# Copie para .env e ajuste conforme o ambiente

# ─── Modo Supabase direto (atual — validação visual) ─────────────────────────
# Ver docs/supabase-direct-mode.md
# Pegue URL e anon key em: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ID do usuário de teste (substitui autenticação real por enquanto)
EXPO_PUBLIC_USER_ID=user_test_1

# ─── Modo API Express (legado — congelado, não usado no momento) ─────────────
# Reativar quando o backend Express + Prisma voltar a ser a fonte de dados.
# Emulador Android: use 10.0.2.2 (aponta para localhost do host)
# Emulador iOS / Expo Go no mesmo Mac: use localhost ou 127.0.0.1
# Celular físico: use o IP local da sua máquina (ex: 192.168.1.42)
# EXPO_PUBLIC_API_URL=http://localhost:3333
